# MARDA backend env vars (server/.env). NUNCA committear .env real.

NODE_ENV=development
PORT=3000

# Postgres (Railway lo inyecta como DATABASE_URL en produccion)
DATABASE_URL=postgresql://user:pass@localhost:5432/marda

# Token JWT — generar uno fuerte: openssl rand -hex 32
JWT_SECRET=change-me-min-32-chars-________________________________

# Admin seed (solo necesario en el primer arranque/seed)
ADMIN_USERNAME=mardadmin
ADMIN_INITIAL_PASSWORD=cambiar-en-produccion-min-8-chars

# CORS (lista separada por coma de origenes permitidos en prod)
# En dev se acepta cualquier origen. En prod, solo estos.
CORS_ORIGINS=https://marda.com.ar,https://www.marda.com.ar

# Carpeta de assets estaticos (build de Vite). Por defecto ../dist
STATIC_DIR=../dist
