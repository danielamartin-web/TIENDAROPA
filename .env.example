# MARDA - env vars (frontend Vite)
# Solo variables con prefijo VITE_ se inyectan al bundle del navegador.

# URL publica del sitio (sin slash final). Se usa para canonical, OG, sitemap dinamico.
VITE_SITE_URL=https://marda.com.ar

# URL base de la API backend (ver /server). Default vacio = mismo origen.
VITE_API_URL=

# IMPORTANTE: las credenciales admin viven en el backend (.env del server, NO aca).
# Cualquier VITE_* termina en el bundle publico.
